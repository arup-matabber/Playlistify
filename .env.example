# Spotify OAuth Environment Variables

# Spotify Developer App Credentials
# Get these from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# OAuth Redirect URI
# Must match exactly what's configured in your Spotify App settings
# For local development:
SPOTIFY_REDIRECT_URI=http://localhost:3001/auth/callback
# For production, update to your deployed URL:
# SPOTIFY_REDIRECT_URI=https://your-domain.com/auth/callback

# Frontend URL
# Where users will be redirected after authentication
# For local development:
FRONTEND_URL=http://localhost:5500
# For production:
# FRONTEND_URL=https://your-domain.com

# Server Port
PORT=3001

# Optional: Feature Flags
ENABLE_NLP=true
ENABLE_CACHE=true
ENABLE_RATE_LIMITING=true
